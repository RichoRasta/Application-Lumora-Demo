{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and learning progress",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "progress": {
          "type": "object",
          "properties": {
            "completedLessons": { "type": "array", "maxItems": 200 },
            "bookmarks": { "type": "array", "maxItems": 200 },
            "streak": { "type": "number" },
            "lastActive": { "type": "string" }
          }
        },
        "createdAt": {
          "type": "string"
        }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User progress storage"
    }
  }
}
